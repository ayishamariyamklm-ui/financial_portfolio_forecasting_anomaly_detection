# ============================================================
# Financial Portfolio Forecasting & Anomaly Detection
# Environment Variables Example
# ============================================================

# ------------------------------------------------------------
# Project Configuration
# ------------------------------------------------------------

PROJECT_NAME=financial-portfolio-forecasting-anomaly-detection
PROJECT_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True


# ------------------------------------------------------------
# Directory Paths
# ------------------------------------------------------------

DATA_RAW_PATH=data/raw/financial_portfolio_data.csv
DATA_PROCESSED_DIR=data/processed
MODEL_DIR=models
REPORTS_DIR=reports
LOG_DIR=logs
OUTPUT_DIR=outputs


# ------------------------------------------------------------
# Processed Data Paths
# ------------------------------------------------------------

CLEANED_DATA_PATH=data/processed/cleaned_financial_data.csv
DAILY_ASSET_PRICES_PATH=data/processed/daily_asset_prices.csv
TRAIN_DATA_PATH=data/processed/train_data.csv
TEST_DATA_PATH=data/processed/test_data.csv
ANOMALY_RESULTS_PATH=data/processed/anomaly_results.csv


# ------------------------------------------------------------
# Sample Input Path
# ------------------------------------------------------------

SAMPLE_PREDICTION_INPUT_PATH=data/sample/sample_prediction_input.csv


# ------------------------------------------------------------
# Model Artifact Paths
# ------------------------------------------------------------

FORECASTING_MODEL_PATH=models/forecasting_model.pkl
ANOMALY_MODEL_PATH=models/anomaly_detection_model.pkl
SCALER_PATH=models/scaler.pkl
FEATURE_COLUMNS_PATH=models/feature_columns.json


# ------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------

LOG_LEVEL=INFO
LOG_FILE=logs/app.log


# ------------------------------------------------------------
# Time Series Forecasting Configuration
# ------------------------------------------------------------

DATE_COLUMN=date
TARGET_COLUMN=portfolio_value
FORECAST_HORIZON_DAYS=30
TEST_SIZE=0.2
RANDOM_STATE=42


# ------------------------------------------------------------
# Anomaly Detection Configuration
# ------------------------------------------------------------

ANOMALY_CONTAMINATION=0.05
ANOMALY_SCORE_THRESHOLD=0.6


# ------------------------------------------------------------
# Financial Portfolio Configuration
# ------------------------------------------------------------

PORTFOLIO_ID_COLUMN=portfolio_id
ASSET_COLUMN=asset_name
ASSET_TYPE_COLUMN=asset_type
PRICE_COLUMN=price
QUANTITY_COLUMN=quantity
VALUE_COLUMN=asset_value
RETURN_COLUMN=daily_return


# ------------------------------------------------------------
# API Configuration
# ------------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True


# ------------------------------------------------------------
# Streamlit Dashboard Configuration
# ------------------------------------------------------------

STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8501


# ------------------------------------------------------------
# Optional Financial Data API Keys
# Do not put real keys in this file.
# Add real keys only in your local .env file.
# ------------------------------------------------------------

ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
YAHOO_FINANCE_API_KEY=your_yahoo_finance_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here


# ------------------------------------------------------------
# Database Configuration Optional
# ------------------------------------------------------------

DATABASE_URL=sqlite:///data/financial_portfolio.db


# ------------------------------------------------------------
# MLflow Optional Experiment Tracking
# ------------------------------------------------------------

MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=financial_portfolio_forecasting


# ------------------------------------------------------------
# Docker Configuration
# ------------------------------------------------------------

DOCKER_APP_PORT=8000
DOCKER_DASHBOARD_PORT=8501


# ------------------------------------------------------------
# Security
# ------------------------------------------------------------

SECRET_KEY=replace_this_with_a_secure_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=60